# ==========================================
# LiteX Firmware Makefile
# ==========================================

# 1. Update this to point to your LiteX build directory
LITEX_BUILD_DIR ?= ../build/basys3

# 2. Toolchain configuration
TRIPLE ?= riscv64-unknown-elf
CC      = $(TRIPLE)-gcc
OBJCOPY = $(TRIPLE)-objcopy

# 3. Architecture Flags
# Adjust these based on your custom 5-stage RISC-V
MARCH ?= rv32i
MABI  ?= ilp32

# ==========================================

# Includes generated by LiteX
# Includes generated by LiteX
# Includes generated by LiteX
INCLUDES = \
	-I../build/basys3/software/include \
	-I../build/basys3/software/include/base \
	-I../build/basys3/software/include/libc

# Compilation Flags
CFLAGS = -O2 -Wall -march=$(MARCH) -mabi=$(MABI) $(INCLUDES)
CFLAGS += -ffreestanding -nostdlib -fno-builtin

# Linker Scripts (Memory regions and formats defined by LiteX)
LDFLAGS = \
	-T linker.ld \
	-L$(LITEX_BUILD_DIR)/software/libbase \
	-L$(LITEX_BUILD_DIR)/software/libcompiler_rt \
	-L$(LITEX_BUILD_DIR)/software/libc \
	-nostdlib \
	-nodefaultlibs

all: crt0.o firmware.bin

# LiteX Startup Code
# Compile custom startup
crt0.o: crt0.S
	$(CC) $(CFLAGS) -c $< -o $@

CRT0 = crt0.o

# Required LiteX Libraries (libc for stdio, libbase for UART, libcompiler_rt for math/builtins)
LIBS = -lc -lbase -lcompiler_rt

# ==========================================
# Build Rules
# ==========================================


firmware.elf: main.c
	$(CC) $(CFLAGS) $(CRT0) $< $(LDFLAGS) -o $@ $(LIBS)

firmware.bin: firmware.elf
	$(OBJCOPY) -O binary $< $@

clean:
	rm -f firmware.elf firmware.bin

.PHONY: all clean
